  "panels": [
    {
      "id": 1,
      "type": "bargauge",
      "title": "Top pending consumers (num_pending)",
      "description": "Unconsumed messages waiting per durable consumer, right now. The headline answer to \"how many pending messages\" — highest backlog first.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "topk(15, jetstream_consumer_num_pending)",
          "legendFormat": "{{stream_name}} / {{consumer_name}}",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Pending by consumer (num_pending)",
      "description": "Messages in the stream the consumer has not yet been delivered. A rising line means the consumer is falling behind the producers.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "jetstream_consumer_num_pending",
          "legendFormat": "{{stream_name}} / {{consumer_name}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "In-flight / unacked by consumer (num_ack_pending)",
      "description": "Messages delivered to the consumer but not yet acked. Sustained high values point at slow handlers or AckWait redeliveries.",
