    }
  ],
  "liveNow": false,
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Messages retained (all streams)",
      "description": "Total messages currently stored across every JetStream stream. Sum of jetstream_stream_total_messages.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null } ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jetstream_stream_total_messages{stream_name=~\"$stream\"})",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Publish rate",
      "description": "Messages published per second across the selected streams. Derived from the rate of jetstream_stream_last_seq (monotonic), which counts publishes even when retention deletes older messages.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(jetstream_stream_last_seq{stream_name=~\"$stream\"}[$__rate_interval]))",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Ack rate",
      "description": "Messages acknowledged (fully processed) per second across the selected streams. Derived from the rate of jetstream_consumer_ack_floor_stream_seq.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(jetstream_consumer_ack_floor_stream_seq{stream_name=~\"$stream\"}[$__rate_interval]))",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Unprocessed (pending)",
      "description": "Messages published but not yet delivered to a consumer, summed over all consumers on the selected streams. Sum of jetstream_consumer_num_pending.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jetstream_consumer_num_pending{stream_name=~\"$stream\"})",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "In-flight (ack pending)",
      "description": "Messages delivered to consumers but not yet acked, summed over the selected streams. Sum of jetstream_consumer_num_ack_pending.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jetstream_consumer_num_ack_pending{stream_name=~\"$stream\"})",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Redelivered",
      "description": "Messages currently scheduled for redelivery (Nak'd or AckWait-expired) across the selected streams. Non-zero means handlers are failing or timing out. Sum of jetstream_consumer_num_redelivered.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jetstream_consumer_num_redelivered{stream_name=~\"$stream\"})",
          "instant": true
        }
      ]
    },
    {
      "id": 101,
      "type": "row",
      "title": "Throughput — message rate",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Publish rate by stream (msg/s)",
      "description": "Per-stream publish throughput, derived from rate(jetstream_stream_last_seq). Each stream owns a subject namespace (e.g. MESSAGES_* carries chat.user.*...msg.>), so this is the closest per-subject view the exporter exposes.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": [ "lastNotNull", "mean", "max" ] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(jetstream_stream_last_seq{stream_name=~\"$stream\"}[$__rate_interval])",
          "legendFormat": "{{stream_name}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Delivery vs ack rate by consumer (msg/s)",
      "description": "Per-consumer delivery throughput (rate of delivered_stream_seq) vs. ack throughput (rate of ack_floor_stream_seq). A persistent gap between the two means messages are being delivered faster than the handler can ack them.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": [ "lastNotNull", "max" ] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(jetstream_consumer_delivered_stream_seq{stream_name=~\"$stream\"}[$__rate_interval])",
          "legendFormat": "delivered · {{stream_name}}/{{consumer_name}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(jetstream_consumer_ack_floor_stream_seq{stream_name=~\"$stream\"}[$__rate_interval])",
          "legendFormat": "acked · {{stream_name}}/{{consumer_name}}"
        }
      ]
    },
    {
      "id": 102,
      "type": "row",
      "title": "Backlog — unprocessed messages",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "panels": []
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Pending by stream / consumer (num_pending)",
      "description": "Messages in the stream the consumer has not yet been delivered — the unprocessed backlog. A rising line means the consumer is falling behind its producers.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": [ "lastNotNull", "max" ] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jetstream_consumer_num_pending{stream_name=~\"$stream\"}",
          "legendFormat": "{{stream_name}} / {{consumer_name}}"
        }
      ]
    },
    {
      "id": 21,
      "type": "bargauge",
      "title": "Top pending consumers (num_pending)",
      "description": "Unconsumed messages waiting per durable consumer, right now — highest backlog first. The headline answer to \"how many messages are pending\".",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "continuous-GrYlRd" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(15, jetstream_consumer_num_pending{stream_name=~\"$stream\"})",
          "legendFormat": "{{stream_name}} / {{consumer_name}}",
          "instant": true
        }
      ]
    },
    {
      "id": 103,
      "type": "row",
      "title": "Ack health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "panels": []
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "In-flight / unacked by consumer (num_ack_pending)",
      "description": "Messages delivered to the consumer but not yet acked. Sustained high values point at slow handlers or AckWait redeliveries.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": [ "lastNotNull", "max" ] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jetstream_consumer_num_ack_pending{stream_name=~\"$stream\"}",
          "legendFormat": "{{stream_name}} / {{consumer_name}}"
        }
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Redelivered by consumer (num_redelivered)",
      "description": "Messages currently scheduled for redelivery (Nak'd or AckWait-expired). Non-zero means handlers are failing or timing out.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": [ "lastNotNull", "max" ] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jetstream_consumer_num_redelivered{stream_name=~\"$stream\"}",
          "legendFormat": "{{stream_name}} / {{consumer_name}}"
        }
      ]
    },
    {
      "id": 104,
      "type": "row",
      "title": "Stream & consumer sizing",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "panels": []
    },
    {
      "id": 40,
      "type": "timeseries",
      "title": "Messages retained by stream",
      "description": "Messages currently stored in each stream (jetstream_stream_total_messages). Context for the per-consumer pending lines above.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": [ "lastNotNull", "max" ] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jetstream_stream_total_messages{stream_name=~\"$stream\"}",
          "legendFormat": "{{stream_name}}"
        }
      ]
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Bytes retained by stream",
      "description": "On-disk bytes stored in each stream (jetstream_stream_total_bytes). Watch for streams approaching a MaxBytes limit.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": [ "lastNotNull", "max" ] },
        "tooltip": { "mode": "multi", "sort": "desc" }
