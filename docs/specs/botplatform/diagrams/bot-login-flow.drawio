<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="bot-login-flow">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Bot Login — End-to-End Flow" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#263238;" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="1600" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Site-scoped hostname → cross-cluster fz2→fz1 → provisioning-gated validate + bp_ token issue" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#546E7A;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="50" width="1600" height="20" as="geometry" />
        </mxCell>

        <!-- Actors row -->
        <mxCell id="actor_bot" value="Bot (SDK)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="actor_dns" value="DNS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="100" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="actor_chatgw" value="chat-GW (fz2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="100" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="actor_wspgw" value="wsp-GW (fz1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="100" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="actor_bps" value="botplatform-service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="940" y="100" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="actor_mongo" value="Mongo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4d6;strokeColor=#b8860b;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1200" y="100" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="actor_valkey" value="Valkey" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4d6;strokeColor=#b8860b;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1360" y="100" width="120" height="50" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="ll_bot" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#90A4AE;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="130" y="150" as="sourcePoint" /><mxPoint x="130" y="1230" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll_dns" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#90A4AE;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="350" y="150" as="sourcePoint" /><mxPoint x="350" y="1230" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll_chatgw" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#90A4AE;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="570" y="150" as="sourcePoint" /><mxPoint x="570" y="1230" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll_wspgw" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#90A4AE;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="790" y="150" as="sourcePoint" /><mxPoint x="790" y="1230" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll_bps" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#90A4AE;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="150" as="sourcePoint" /><mxPoint x="1030" y="1230" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll_mongo" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#90A4AE;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="150" as="sourcePoint" /><mxPoint x="1260" y="1230" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll_valkey" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#90A4AE;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1420" y="150" as="sourcePoint" /><mxPoint x="1420" y="1230" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Step 1: Bot -> DNS -->
        <mxCell id="m1" value="1. resolve botpltfr-siteA.chat-test.test.xx.com" style="edgeStyle=none;html=1;endArrow=classic;strokeColor=#37474F;fontSize=12;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="130" y="200" as="sourcePoint" /><mxPoint x="350" y="200" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m2" value="2. A record → fz2 chat-GW IP" style="edgeStyle=none;html=1;endArrow=classic;dashed=1;strokeColor=#37474F;fontSize=12;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="350" y="250" as="sourcePoint" /><mxPoint x="130" y="250" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Step 3: Bot -> chat-GW (HTTPS request) -->
        <mxCell id="m3" value="3. POST /api/v1/login&#xa;{ user: 'xxx.bot', password }" style="edgeStyle=none;html=1;endArrow=classic;strokeColor=#1565C0;strokeWidth=2;fontSize=12;fontStyle=1;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="130" y="330" as="sourcePoint" /><mxPoint x="570" y="330" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Step 4: chat-GW -> wsp-GW (cross-cluster) -->
        <mxCell id="m4" value="4. VirtualService weight Y% → wsp-GW (cross-cluster, mTLS, SNI=chat-test)" style="edgeStyle=none;html=1;endArrow=classic;strokeColor=#EF6C00;strokeWidth=3;fontSize=12;fontStyle=1;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="570" y="410" as="sourcePoint" /><mxPoint x="790" y="410" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Step 5: wsp-GW -> botplatform-service -->
        <mxCell id="m5" value="5. route → botplatform-service.wsp.svc:8080" style="edgeStyle=none;html=1;endArrow=classic;strokeColor=#1565C0;strokeWidth=2;fontSize=12;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="790" y="490" as="sourcePoint" /><mxPoint x="1030" y="490" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Step 6: in-process activation on botplatform lifeline -->
        <mxCell id="m6_act" value="6. IsValidBotAccount" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#B8860B;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="970" y="540" width="180" height="30" as="geometry" />
        </mxCell>

        <!-- Step 7: botplatform -> mongo find user by account -->
        <mxCell id="m7" value="7. db.users.findOne({account}) — read services.password.bcrypt" style="edgeStyle=none;html=1;endArrow=classic;strokeColor=#37474F;fontSize=12;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="610" as="sourcePoint" /><mxPoint x="1260" y="610" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m8" value="8. user { services.password.bcrypt, requirePasswordChange, siteId, roles }" style="edgeStyle=none;html=1;endArrow=classic;dashed=1;strokeColor=#37474F;fontSize=11;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="660" as="sourcePoint" /><mxPoint x="1030" y="660" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Step 9: in-process bcrypt -->
        <mxCell id="m9_act" value="9. bcrypt verify (constant-time)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#B8860B;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="960" y="700" width="200" height="30" as="geometry" />
        </mxCell>

        <!-- Step 10: PROVISIONING GATE — in-process field check on user doc from step 8 (NO Mongo round-trip) -->
        <mxCell id="m10_act" value="10. PROVISIONING GATE (in-process, no extra Mongo) — if u.siteId != SITE_ID → 403 account_not_provisioned" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="775" width="510" height="30" as="geometry" />
        </mxCell>

        <!-- Step 12: in-process token gen (green) -->
        <mxCell id="m12_act" value="12. issue v1 token (bp_ + HMAC-SHA-256)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=11;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="930" y="870" width="260" height="30" as="geometry" />
        </mxCell>

        <!-- Step 13: INSERT sessions row -->
        <mxCell id="m13" value="13. db.sessions.insertOne({ _id: hash, userId, account, siteId, scheme:'v1', issuedAt: now })" style="edgeStyle=none;html=1;endArrow=classic;strokeColor=#2E7D32;strokeWidth=2;fontSize=11;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="940" as="sourcePoint" /><mxPoint x="1260" y="940" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Step 13b: cap enforcement — count + delete oldest by issuedAt -->
        <mxCell id="m13b_act" value="13b. cap check — over := count({userId}) - SESSIONS_MAX_PER_ACCOUNT; if over > 0: find({userId}).sort({issuedAt:1}).limit(over) → deleteMany + valkey.del each victim (FIFO by issuedAt)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=10;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="965" width="550" height="30" as="geometry" />
        </mxCell>

        <!-- Step 14: warm Valkey -->
        <mxCell id="m14" value="14. SETEX hash → principal (TTL 5m)" style="edgeStyle=none;html=1;endArrow=classic;strokeColor=#2E7D32;fontSize=12;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="1015" as="sourcePoint" /><mxPoint x="1420" y="1015" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Step 15: response botplatform -> wsp-GW -->
        <mxCell id="m15" value="15. 200 { authToken:'bp_…', userId, me }" style="edgeStyle=none;html=1;endArrow=classic;dashed=1;strokeColor=#1565C0;strokeWidth=2;fontSize=12;fontStyle=1;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="1070" as="sourcePoint" /><mxPoint x="790" y="1070" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Step 16: wsp-GW -> chat-GW (cross-cluster return) -->
        <mxCell id="m16" value="16. cross-cluster return (mTLS)" style="edgeStyle=none;html=1;endArrow=classic;dashed=1;strokeColor=#EF6C00;fontSize=12;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="790" y="1130" as="sourcePoint" /><mxPoint x="570" y="1130" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Step 17: chat-GW -> Bot (final response) -->
        <mxCell id="m17" value="17. 200 + envelope (RC-compatible, byte-for-byte)" style="edgeStyle=none;html=1;endArrow=classic;dashed=1;strokeColor=#1565C0;strokeWidth=2;fontSize=12;fontStyle=1;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="570" y="1190" as="sourcePoint" /><mxPoint x="130" y="1190" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Side annotation panel: details that would otherwise crowd the arrows -->
        <mxCell id="ann_title" value="Step details" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#37474F;" vertex="1" parent="1">
          <mxGeometry x="1530" y="190" width="240" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ann_3" value="(3) Host header set to the site-scoped hostname; body may use plaintext or RC digest form" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#6C8EBF;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1530" y="220" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ann_4" value="(4) Routing via Istio multi-cluster mesh OR ServiceEntry; DestinationRule pins SNI so wsp-GW serves the chat-cert" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1530" y="300" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ann_6" value="(6) IsValidBotAccount allows ^[A-Za-z0-9_-]+\.bot$ (xxx.bot, yyy.bot)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#B8860B;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1530" y="450" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ann_9" value="(9) bcrypt.CompareHashAndPassword(passwordHash, sha256_hex(plaintext)); dummy compare on unknown account for timing uniformity" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#B8860B;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1530" y="620" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ann_10" value="(10) In-process field check on user doc from step 8 — NO extra Mongo query. REQUIRE_PROVISIONED=true default; mirrors auth-service from PR #295. Fail-closed if u.siteId missing." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1530" y="760" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ann_12" value="(12) raw = 'bp_' + base64url(crypto/rand.Read(32))   hash = base64(HMAC-SHA-256(TOKEN_HMAC_KEY, raw))" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1530" y="860" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ann_13" value="(13) One INSERT per login into the dedicated `sessions` collection (NEW, owned by botplatform-service). Sessions are PERMANENT — no expiresAt, no TTL index. Cap-eviction (FIFO by issuedAt) or admin-revoke are the only removal paths. IXSCAN on {userId, issuedAt} compound serves both 13b and admin list/revoke." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#EF6C00;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1530" y="950" width="240" height="130" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="LEGEND  &#xa;━━ blue: client / gateway HTTP hop    ━━ orange: cross-cluster mTLS&#xa;━━ green: token issue + cache    ━━ grey: store lookup    ┄┄ dashed: response&#xa;yellow box: in-process validation step on botplatform-service lifeline&#xa;red box: in-process security gate (fail-closed; no extra Mongo query)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#90A4AE;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="1250" width="900" height="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
