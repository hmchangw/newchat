<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="cross-cluster-cutover">
    <mxGraphModel dx="2000" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Cross-Cluster Cutover Topology — fz2/chat → fz1/wsp" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#263238;" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="1800" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="DNS *.chat-test.* locked to fz2 (per-ns binding). chat-GW is the permanent front door; cutover = chat-GW VirtualService weight shift cross-cluster to wsp-GW." style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#546E7A;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="50" width="1800" height="20" as="geometry" />
        </mxCell>

        <!-- TOP: Bot client -->
        <mxCell id="bot" value="Bot (SDK)&#xa;dials botpltfr-siteA.chat-test.test.xx.com" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="110" width="320" height="60" as="geometry" />
        </mxCell>

        <!-- TOP: Public DNS -->
        <mxCell id="dns" value="Public DNS  (per-namespace binding)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="500" y="100" width="800" height="80" as="geometry" />
        </mxCell>
        <mxCell id="dns_rows" value="A   *.chat-test.test.xx.com   →   fz2 VIP&#xa;A   *.wsp-test.test.xx.com    →   fz1 VIP&#xa;chat ns CANNOT be repointed to wsp gateway" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="125" width="760" height="50" as="geometry" />
        </mxCell>

        <!-- TOP: Ops note -->
        <mxCell id="ops" value="Ops / SRE&#xa;edits chat-GW VirtualService weights&#xa;(the only canary control surface)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="1400" y="110" width="500" height="60" as="geometry" />
        </mxCell>

        <!-- Cluster fz2 (LEFT) -->
        <mxCell id="fz2" value="Cluster fz2  (legacy)" style="swimlane;startSize=30;fillColor=#ECEFF1;strokeColor=#546E7A;fontSize=14;fontStyle=1;swimlaneFillColor=#FAFAFA;" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="900" height="980" as="geometry" />
        </mxCell>

        <mxCell id="chat_ns" value="Namespace: chat" style="swimlane;startSize=24;fillColor=#FFF8E1;strokeColor=#B8860B;fontSize=12;fontStyle=1;swimlaneFillColor=#FFFDE7;" vertex="1" parent="fz2">
          <mxGeometry x="20" y="50" width="860" height="910" as="geometry" />
        </mxCell>

        <mxCell id="chatgw" value="chat-gateway  (Istio)&#xa;permanent front door — DNS is locked here&#xa;listener: 443 *.chat-test.test.xx.com (chat-cert)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="chat_ns">
          <mxGeometry x="40" y="40" width="780" height="80" as="geometry" />
        </mxCell>

        <mxCell id="chatvs_title" value="VirtualService  botpltfr-*.chat-test.test.xx.com  (chat-GW canary control surface)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4D6;strokeColor=#B8860B;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="chat_ns">
          <mxGeometry x="40" y="160" width="780" height="180" as="geometry" />
        </mxCell>
        <mxCell id="chatvs_body" value="destinations:&#xa;  • legacy-botplatform.chat.svc.cluster.local         weight: X     (LOCAL, in fz2/chat)&#xa;  • wsp-gateway.fz1.internal:443                       weight: Y     (CROSS-CLUSTER)&#xa;&#xa;canary ramp:&#xa;  Phase 0   100 / 0  →  Phase 1   99 / 1  →  Phase 2   90 / 10&#xa;  Phase 3    50 / 50  →  Phase 4    0 / 100  →  Phase 5   sunset legacy&#xa;&#xa;rollback at any step = shift weights back via &#x27;kubectl apply&#x27; (instant)" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="chat_ns">
          <mxGeometry x="60" y="185" width="740" height="150" as="geometry" />
        </mxCell>

        <mxCell id="se_dr_title" value="DestinationRule + ServiceEntry  →  wsp-gateway.fz1.internal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="chat_ns">
          <mxGeometry x="40" y="370" width="780" height="100" as="geometry" />
        </mxCell>
        <mxCell id="se_dr_body" value="TLS mode SIMPLE,  SNI = botpltfr-siteA.chat-test.test.xx.com&#xa;(critical: makes wsp-GW serve from the chat-cert listener, not the wsp-cert one)" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="chat_ns">
          <mxGeometry x="60" y="395" width="740" height="70" as="geometry" />
        </mxCell>

        <mxCell id="legacy" value="legacy-botplatform-service&#xa;(existing v2 / Meteor / Rocket.Chat)&#xa;LOCAL destination — removed after Phase 5 sunset" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="chat_ns">
          <mxGeometry x="40" y="510" width="780" height="80" as="geometry" />
        </mxCell>

        <mxCell id="legacy_mongo" value="Legacy Mongo&#xa;users.services.password.bcrypt&#xa;users.services.resume.loginTokens[]" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=center;" vertex="1" parent="chat_ns">
          <mxGeometry x="40" y="620" width="380" height="100" as="geometry" />
        </mxCell>

        <mxCell id="lf_note_title" value="After Phase 5 sunset" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#90A4AE;fontSize=11;fontStyle=1;align=center;verticalAlign=top;" vertex="1" parent="chat_ns">
          <mxGeometry x="440" y="620" width="380" height="280" as="geometry" />
        </mxCell>
        <mxCell id="lf_note_body" value="• chat-GW stays — DNS still points here&#xa;• legacy pods removed&#xa;• VirtualService becomes 0 / 100 forever&#xa;• chat-GW becomes a permanent thin forwarder&#xa;• HA chat-GW accordingly — its blast radius&#xa;  is now load-bearing&#xa;• DNS-repoint to wsp-GW NOT possible later&#xa;  either (per-ns DNS binding)" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="chat_ns">
          <mxGeometry x="460" y="650" width="350" height="240" as="geometry" />
        </mxCell>

        <!-- Cluster fz1 (RIGHT) -->
        <mxCell id="fz1" value="Cluster fz1  (nextgen)" style="swimlane;startSize=30;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=14;fontStyle=1;swimlaneFillColor=#F1F8E9;" vertex="1" parent="1">
          <mxGeometry x="1000" y="220" width="940" height="980" as="geometry" />
        </mxCell>

        <mxCell id="wsp_ns" value="Namespace: wsp" style="swimlane;startSize=24;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=12;fontStyle=1;swimlaneFillColor=#F1F8E9;" vertex="1" parent="fz1">
          <mxGeometry x="20" y="50" width="900" height="910" as="geometry" />
        </mxCell>

        <mxCell id="wspgw_title" value="wsp-gateway  (Istio)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="wsp_ns">
          <mxGeometry x="20" y="40" width="860" height="120" as="geometry" />
        </mxCell>
        <mxCell id="wspgw_body" value="listeners on 443:&#xa;  • *.wsp-test.test.xx.com    (wsp-cert)    — own domain&#xa;  • *.chat-test.test.xx.com   (chat-cert)   ← NEW: accepts chat host via SNI&#xa;the new chat-host listener is what makes the cross-cluster forward possible" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="wsp_ns">
          <mxGeometry x="40" y="65" width="820" height="90" as="geometry" />
        </mxCell>

        <mxCell id="wspvs" value="VirtualService  botpltfr-*.chat-test.test.xx.com   →   botplatform-service.wsp.svc.cluster.local:8080" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;" vertex="1" parent="wsp_ns">
          <mxGeometry x="20" y="190" width="860" height="50" as="geometry" />
        </mxCell>

        <mxCell id="bps_title" value="botplatform-service   (NEW — we build)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="wsp_ns">
          <mxGeometry x="20" y="270" width="860" height="120" as="geometry" />
        </mxCell>
        <mxCell id="bps_body" value="login   /api/v1/login,  /v1/bot/login&#xa;web    /dev-login,  /changepwd,  /admin/bots/*&#xa;validate    POST /v1/auth/validate    (dual-token authority — called by ApiGW / WS / EventConsumer)&#xa;owns:    credentials + sessions    (Mongo + Valkey)" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="wsp_ns">
          <mxGeometry x="40" y="295" width="820" height="90" as="geometry" />
        </mxCell>

        <mxCell id="apigw" value="ApiGW   (existing)&#xa;routes /api/v2/* → Server&#xa;calls /v1/auth/validate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;" vertex="1" parent="wsp_ns">
          <mxGeometry x="20" y="420" width="420" height="80" as="geometry" />
        </mxCell>
        <mxCell id="server" value="Server   (existing botplatform-server :8080)&#xa;serves /api/v2/* (legacy v2 REST)&#xa;trusts ApiGW principal headers under mTLS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;" vertex="1" parent="wsp_ns">
          <mxGeometry x="460" y="420" width="420" height="80" as="geometry" />
        </mxCell>

        <mxCell id="ws" value="WebSocket server :8899&#xa;calls /v1/auth/validate ONCE per connect&#xa;caches principal class for connection lifetime" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;" vertex="1" parent="wsp_ns">
          <mxGeometry x="20" y="530" width="420" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ec" value="EventConsumer  (NATS → webhook)&#xa;calls /v1/auth/validate per event&#xa;tags every published event with class" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;" vertex="1" parent="wsp_ns">
          <mxGeometry x="460" y="530" width="420" height="80" as="geometry" />
        </mxCell>

        <mxCell id="mongo" value="Mongo   (nextgen chat DB)&#xa;users (shared, password in-place) + sessions (new, one doc per session)&#xa;Provisioning gate = in-process field check on the user doc loaded for password verify (no extra Mongo round-trip)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#fff4d6;strokeColor=#b8860b;fontSize=10;align=center;" vertex="1" parent="wsp_ns">
          <mxGeometry x="20" y="650" width="420" height="120" as="geometry" />
        </mxCell>
        <mxCell id="valkey" value="Valkey  (cluster mode)&#xa;hot cache for /v1/auth/validate&#xa;TTL 5m,  HMAC-keyed lookups" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#fff4d6;strokeColor=#b8860b;fontSize=11;align=center;" vertex="1" parent="wsp_ns">
          <mxGeometry x="460" y="650" width="420" height="120" as="geometry" />
        </mxCell>

        <!-- Arrows -->
        <mxCell id="e_bot_dns" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#37474F;" edge="1" parent="1" source="bot" target="dns">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_dns_chatgw" value="(1) resolves to fz2 VIP" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#37474F;fontSize=10;" edge="1" parent="1" source="dns" target="chatgw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_ops_chatvs" value="kubectl apply&#xa;weight shift" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.1;dashed=1;strokeColor=#D6B656;fontSize=10;" edge="1" parent="1" source="ops" target="chatvs_title">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_chatgw_chatvs" value="(2) chat-GW evaluates VirtualService" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#37474F;fontSize=10;" edge="1" parent="1" source="chatgw" target="chatvs_title">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_chatvs_legacy" value="weight X% (LOCAL)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.3;exitY=1;entryX=0.3;entryY=0;strokeColor=#B85450;strokeWidth=2;fontSize=11;fontStyle=1;" edge="1" parent="1" source="chatvs_title" target="legacy">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="304" y="500" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e_chatvs_se" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.7;exitY=1;entryX=0.7;entryY=0;strokeColor=#37474F;" edge="1" parent="1" source="chatvs_title" target="se_dr_title">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_se_wspgw" value="weight Y%   CROSS-CLUSTER mTLS&#xa;Istio multi-cluster mesh OR ServiceEntry" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.3;strokeColor=#EF6C00;strokeWidth=4;fontSize=12;fontStyle=1;" edge="1" parent="1" source="se_dr_title" target="wspgw_title">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_wspgw_vs" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#37474F;" edge="1" parent="1" source="wspgw_title" target="wspvs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_vs_bps" value="chat-host VS →" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#2E7D32;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="wspvs" target="bps_title">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_apigw_bps" value="/v1/auth/validate" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.25;exitY=0;entryX=0.25;entryY=1;strokeColor=#6C8EBF;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="apigw" target="bps_title">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_apigw_server" value="mTLS + X-Principal-Class" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#1565C0;strokeWidth=2;fontSize=10;fontStyle=1;" edge="1" parent="1" source="apigw" target="server">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_ws_bps" value="validate per connect" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;dashed=1;strokeColor=#6C8EBF;fontSize=10;" edge="1" parent="1" source="ws" target="bps_title">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="230" y="410" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_ec_bps" value="validate per event" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=0;entryX=0.75;entryY=1;dashed=1;strokeColor=#6C8EBF;fontSize=10;" edge="1" parent="1" source="ec" target="bps_title">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="670" y="410" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e_bps_mongo" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.25;exitY=1;entryX=0.5;entryY=0;strokeColor=#B8860B;strokeWidth=2;" edge="1" parent="1" source="bps_title" target="mongo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_bps_valkey" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.75;exitY=1;entryX=0.5;entryY=0;strokeColor=#B8860B;strokeWidth=2;" edge="1" parent="1" source="bps_title" target="valkey">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="LEGEND" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="1220" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg_body" value="━━ orange thick: cross-cluster TLS hop (load-bearing forever)        ━━ red: legacy LOCAL backend (sunset Phase 5)        ━━ green: nextgen primary destination (post-cutover)&#xa;━━ blue: in-mesh data plane / validate call (mTLS)                  ┄┄ dashed: control plane (ops apply) / per-connect validate&#xa;NB: After sunset, X = 0 / Y = 100 permanently. DNS never changes (per-ns binding makes DNS-repoint impossible)." style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="60" y="1245" width="1880" height="50" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
