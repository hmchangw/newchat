<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="token-gen-validate-flow">
    <mxGraphModel dx="2000" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Token Generation &amp; Validation — Dual-Scheme (legacy + v1)" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#263238;" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="1800" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Issuance path on top, validation path with prefix-dispatch on bottom; show how legacy and v1 tokens coexist during the hybrid phase" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#546E7A;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="50" width="1800" height="20" as="geometry" />
        </mxCell>

        <!-- ============== TOP HALF: GENERATION ============== -->
        <mxCell id="gen_band" value="GENERATION (login path)" style="swimlane;startSize=36;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=14;fontStyle=1;fontColor=#1B5E20;swimlaneFillColor=#F1F8E9;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="1880" height="540" as="geometry" />
        </mxCell>

        <mxCell id="g_login" value="POST /api/v1/login&#xa;or /v1/bot/login&#xa;{ user, password }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="gen_band">
          <mxGeometry x="40" y="80" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="g_verify" value="bcrypt verify&#xa;+ provisioning gate&#xa;(see Part II §5.1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8DC;strokeColor=#B8860B;fontSize=11;align=center;" vertex="1" parent="gen_band">
          <mxGeometry x="290" y="80" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="g_rand" value="crypto/rand.Read(32 bytes)&#xa;→ 256 bits of entropy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=11;align=center;" vertex="1" parent="gen_band">
          <mxGeometry x="540" y="80" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="g_b64url" value="base64url(no padding)&#xa;= 43 chars" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=11;align=center;" vertex="1" parent="gen_band">
          <mxGeometry x="830" y="80" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="g_prefix" value="prepend &quot;bp_&quot;&#xa;→ raw = bp_&lt;43 chars&gt;&#xa;= 47 chars total" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#1B5E20;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="gen_band">
          <mxGeometry x="1080" y="80" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="g_hmac" value="hash = base64(&#xa;  HMAC-SHA-256(&#xa;    TOKEN_HMAC_KEY,&#xa;    raw))&#xa;= 44 chars" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#1B5E20;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="gen_band">
          <mxGeometry x="1350" y="60" width="220" height="120" as="geometry" />
        </mxCell>

        <mxCell id="g_persist" value="db.sessions.insertOne({&#xa;  _id: hash, userId, account,&#xa;  siteId, scheme:&#x27;v1&#x27;,&#xa;  issuedAt: now&#xa;})&#xa;+ cap check (count + delete&#xa;  oldest by issuedAt)&#xa;+ SETEX valkey hash → principal&#xa;(no expiresAt, no lastUsedAt)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4D6;strokeColor=#B8860B;fontSize=10;align=center;" vertex="1" parent="gen_band">
          <mxGeometry x="1620" y="50" width="220" height="140" as="geometry" />
        </mxCell>

        <!-- generation flow arrows -->
        <mxCell id="g_a1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#37474F;" edge="1" parent="gen_band" source="g_login" target="g_verify"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="g_a2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#37474F;" edge="1" parent="gen_band" source="g_verify" target="g_rand"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="g_a3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#37474F;" edge="1" parent="gen_band" source="g_rand" target="g_b64url"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="g_a4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#37474F;" edge="1" parent="gen_band" source="g_b64url" target="g_prefix"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="g_a5" value="hash storage" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#2E7D32;strokeWidth=2;fontSize=10;" edge="1" parent="gen_band" source="g_prefix" target="g_hmac"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="g_a6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#B8860B;strokeWidth=2;" edge="1" parent="gen_band" source="g_hmac" target="g_persist"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- response back -->
        <mxCell id="g_response" value="response — bot receives the RAW token (bp_…) in authToken; the HMAC hash never leaves the server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="gen_band">
          <mxGeometry x="40" y="240" width="1800" height="50" as="geometry" />
        </mxCell>

        <!-- separator: two formats coexist -->
        <mxCell id="g_coexist_title" value="Why this shape — design rationale (cross-ref Part II §4.3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=12;fontStyle=1;verticalAlign=top;align=left;" vertex="1" parent="gen_band">
          <mxGeometry x="40" y="320" width="1800" height="180" as="geometry" />
        </mxCell>
        <mxCell id="g_coexist_body" value="bp_ / ad_ per-class prefix     • always-on for new tokens — gates the validator hash-dispatch (next page) so v1 tokens skip the legacy-store probe entirely&#xa;                   • class is self-evident from X-Auth-Token (bp_ = bot, ad_ = admin) — no DB lookup needed to know principal class&#xa;                   • detected by every standard secret scanner (GitHub, gitleaks, trufflehog) when leaked into a public repo&#xa;&#xa;HMAC-SHA-256 storage   • defense in depth — a stolen sessions table is opaque without the server-side TOKEN_HMAC_KEY (plain SHA-256 was a public function)&#xa;                          • cost identical to plain SHA-256 (two SHA-256 ops vs one — both ~free at 1M validations/min)&#xa;                          • bound to a server secret → leaked hash from logs/errors is NOT a usable lookup key&#xa;                          • NOT bcrypt/Argon2 — tokens have 256-bit entropy; slow hashing buys nothing and costs 1,667 cores/min at our rate" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Courier New;" vertex="1" parent="gen_band">
          <mxGeometry x="60" y="345" width="1760" height="150" as="geometry" />
        </mxCell>

        <!-- ============== BOTTOM HALF: VALIDATION ============== -->
        <mxCell id="val_band" value="VALIDATION (every API call — POST /v1/auth/validate)" style="swimlane;startSize=36;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=14;fontStyle=1;fontColor=#0D47A1;swimlaneFillColor=#F5FAFF;" vertex="1" parent="1">
          <mxGeometry x="60" y="680" width="1880" height="700" as="geometry" />
        </mxCell>

        <mxCell id="v_caller" value="ApiGW / WS / EventConsumer&#xa;POST /v1/auth/validate&#xa;{ userId, authToken }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="val_band">
          <mxGeometry x="40" y="80" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="v_dispatch" value="DISPATCH on token prefix" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="val_band">
          <mxGeometry x="340" y="80" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- v1 path (top branch) -->
        <mxCell id="v_v1_hash" value="hash = base64(&#xa;  HMAC-SHA-256(&#xa;    TOKEN_HMAC_KEY,&#xa;    authToken))" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#1B5E20;fontSize=11;align=center;" vertex="1" parent="val_band">
          <mxGeometry x="620" y="60" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- legacy path (bottom branch) -->
        <mxCell id="v_lg_hash" value="hash = base64(&#xa;  sha256(authToken))" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;align=center;" vertex="1" parent="val_band">
          <mxGeometry x="620" y="220" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- merge -->
        <mxCell id="v_cache" value="GETEX valkey hash (EX=5m)&#xa;hot path &lt;5ms cached &gt;95% hit&#xa;GETEX refreshes in-memory TTL (no Mongo write)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4D6;strokeColor=#B8860B;fontSize=10;fontStyle=1;align=center;" vertex="1" parent="val_band">
          <mxGeometry x="900" y="140" width="280" height="80" as="geometry" />
        </mxCell>

        <mxCell id="v_cache_check" value="cache hit?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="val_band">
          <mxGeometry x="1240" y="140" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="v_mongo" value="db.sessions.findOne({_id: hash})&#xa;cold path &lt;50ms; single IXSCAN on _id&#xa;(no array scan; O(1) regardless of cap)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4D6;strokeColor=#B8860B;fontSize=10;align=center;" vertex="1" parent="val_band">
          <mxGeometry x="1240" y="260" width="280" height="80" as="geometry" />
        </mxCell>

        <mxCell id="v_session_check" value="session row&#xa;found?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="val_band">
          <mxGeometry x="1580" y="140" width="180" height="100" as="geometry" />
        </mxCell>

        <mxCell id="v_legacy_fallback" value="legacy-store probe&#xa;(hybrid phase only)&#xa;auth Part III §4.3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;align=center;" vertex="1" parent="val_band">
          <mxGeometry x="1580" y="320" width="180" height="100" as="geometry" />
        </mxCell>

        <!-- terminal nodes -->
        <mxCell id="v_ok" value="✓ return principal&#xa;{ userId, account, roles,&#xa;  class, siteId }&#xa;ApiGW injects X-Principal-Class&#xa;under mTLS to downstream" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#1B5E20;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="val_band">
          <mxGeometry x="900" y="460" width="320" height="120" as="geometry" />
        </mxCell>

        <mxCell id="v_throttle" value="VALIDATE IS PURE-READ&#xa;Activity tracked only via Valkey GETEX TTL refresh (step v_cache).&#xa;NO Mongo writes on this path — no lastUsedAt, no expiresAt bump.&#xa;Sessions are PERMANENT (auth Part II §5.5); cap-eviction + admin revoke are the only removal paths." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=10;fontStyle=1;align=center;" vertex="1" parent="val_band">
          <mxGeometry x="1260" y="460" width="320" height="80" as="geometry" />
        </mxCell>

        <mxCell id="v_fail" value="✗ 401 invalidCredentials&#xa;(no sessionExpired —&#xa;sessions are permanent)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="val_band">
          <mxGeometry x="1580" y="460" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- validation arrows -->
        <mxCell id="va1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#37474F;" edge="1" parent="val_band" source="v_caller" target="v_dispatch"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="va_v1" value="starts with &quot;bp_&quot;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.3;entryX=0;entryY=0.5;strokeColor=#1B5E20;strokeWidth=2;fontSize=10;fontStyle=1;" edge="1" parent="val_band" source="v_dispatch" target="v_v1_hash"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="va_lg" value="no prefix (legacy)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.7;entryX=0;entryY=0.5;strokeColor=#C62828;strokeWidth=2;fontSize=10;fontStyle=1;" edge="1" parent="val_band" source="v_dispatch" target="v_lg_hash"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="va_v1_to_cache" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.3;strokeColor=#37474F;" edge="1" parent="val_band" source="v_v1_hash" target="v_cache"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="va_lg_to_cache" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.7;strokeColor=#37474F;" edge="1" parent="val_band" source="v_lg_hash" target="v_cache"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="va_cache_chk" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#37474F;" edge="1" parent="val_band" source="v_cache" target="v_cache_check"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="va_hit" value="hit" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=1;entryX=0.5;entryY=0;strokeColor=#1B5E20;strokeWidth=2;fontSize=11;fontStyle=1;" edge="1" parent="val_band" source="v_cache_check" target="v_ok"><mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="1200" y="380" /></Array>
          </mxGeometry></mxCell>
        <mxCell id="va_miss" value="miss" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#B8860B;strokeWidth=2;fontSize=11;fontStyle=1;" edge="1" parent="val_band" source="v_cache_check" target="v_mongo"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="va_mongo_chk" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.7;strokeColor=#37474F;" edge="1" parent="val_band" source="v_mongo" target="v_session_check"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="va_found" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=1;entryX=1;entryY=0.2;strokeColor=#1B5E20;strokeWidth=2;fontSize=11;fontStyle=1;" edge="1" parent="val_band" source="v_session_check" target="v_ok"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1560" y="400" /></Array></mxGeometry></mxCell>

        <mxCell id="va_legacy_fb" value="not found AND no bp_ prefix" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#C62828;strokeWidth=2;fontSize=10;fontStyle=1;" edge="1" parent="val_band" source="v_session_check" target="v_legacy_fallback"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="va_legacy_to_fail" value="legacy miss" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#C62828;strokeWidth=2;fontSize=10;" edge="1" parent="val_band" source="v_legacy_fallback" target="v_fail"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1670" y="450" /></Array></mxGeometry></mxCell>

        <mxCell id="va_ok_to_throttle" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;dashed=1;strokeColor=#2E7D32;fontSize=10;" edge="1" parent="val_band" source="v_ok" target="v_throttle"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Bottom legend -->
        <mxCell id="legend" value="LEGEND" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="1280" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg_body" value="green: v1 (native) path        red: legacy path (sunsets after telemetry shows zero live legacy tokens)        yellow: cache / store        blue: caller / response&#xa;diamond = decision      cylinder = store      rounded box = process step      ┄┄ dashed = async (out of band)        Hot path target: P99 &lt;5ms cached, &lt;50ms uncached, 1M validations/min." style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1305" width="1880" height="50" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
